---
import SectionContainer from './items/SectionContainer.astro'
import ProjectItem from './items/ProjectItem.astro'
import { LibraryBig } from 'lucide-astro'
import { getProjects } from '../data/notion'

const projectsData = await getProjects();
---

<SectionContainer id="projects" className="animate-pulse-fade-in animate-delay-300 animate-duration-500">
    <h2 class="text-2xl font-semibold flex gap-3 items-center text-neutral-200">
        <LibraryBig />
        Projects
    </h2>

    <div class="grid gap-3 md:grid-cols-2">
        {projectsData.map(project => (
            <ProjectItem {...project} />
        ))}
    </div>
</SectionContainer>