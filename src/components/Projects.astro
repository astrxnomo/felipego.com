---
import {LibraryBig, MoveRight} from 'lucide-astro'
import Section from './Section.astro'
import ProjectItem from './ProjectItem.astro'

let projects = [
    {
        title: "Eventify",
        description: "An events app to buy and sell tickets.",
        technologies: ["PHP", "Laravel", "MySQL", "Bootstrap"],
        image: "projects-imgs/eventify.jpg",
        githubLink: "https://github.com/astrxnomo/eventify",
    },
    {
        title: "felipego.com",
        description: "My personal website.",
        technologies: ["JavaScript", "Astro", "Tailwind CSS"],
        image: "projects-imgs/felipego.jpg",
        githubLink: "https://github.com/astrxnomo/felipego.com",
        liveLink: "/#top"
    },
    {
        title: "Ticket Bot",
        description: "A Discord bot for tickets management.",
        technologies: ["Python", "Discord.py"],
        image: "projects-imgs/discord-ticket-bot.jpg",
        githubLink: "https://github.com/astrxnomo/discord-ticket-bot-py",
    },
    {
        title: "Diamond Hero",
        description: "A hunger game Minecraft server (+300 participants).",
        technologies: ["Java", "Linux", "Cloud"],
        image: "projects-imgs/diamond-hero.jpg",
        liveLink: "https://www.youtube.com/watch?v=20PBJLrjFEs",
    }
];
---

<Section id="projects" className="animate-pulse-fade-in animate-delay-300 animate-duration-500">
    
    <h2 class="text-2xl font-semibold flex gap-3 items-center text-neutral-200">
        <LibraryBig />
        Projects
    </h2>

    <div class="grid gap-3 md:grid-cols-2">
        {projects.map(project => <ProjectItem project={project} />)}
    </div>


    <a href="https://github.com/astrxnomo" target="_blank" class="inline-flex items-center text-sm justify-center rounded-xl bg-neutral-800 dark:hover:text-neutral-50 py-2 px-4 opacity-80 transition-opacity duration-150 hover:opacity-100 w-full md:w-auto group gap-2 font-medium ">
        More projects
        <MoveRight class="size-4 opacity-70 group-hover:opacity-100 group-hover:translate-x-[1.5px] duration-200"/>
    </a>
</Section>
