---
import SectionContainer from './items/SectionContainer.astro'
import SocialLinks from './items/SocialLinks.astro'

import {Sprout} from 'lucide-astro'

---

<footer class="pt-0 mb-12 w-full mx-auto flex flex-col gap-6 md:max-w-4xl">
    <SectionContainer id="footer" className="animate-pulse-fade-in animate-delay-500 animate-duration-600">
        <div class="flex justify-between">
            <div class="flex items-center gap-1 text-sm">
                <Sprout size={18} />
                <h2>Felipe Giraldo</h2> 
                <span class="text-gray-500">-</span> 
                <p>2024</p>
            </div>
    
            <SocialLinks />
        </div>
    </SectionContainer>
</footer>